# .env.example
# =============
# Copy this file to .env and fill in your real values.
# NEVER commit your actual .env file to version control.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your real secrets
#   # python-dotenv loads it automatically when manage.py starts

# ---------------------------------------------------------------------------
# Django Core
# ---------------------------------------------------------------------------

# Secret key for cryptographic signing (sessions, CSRF tokens, etc.)
# Generate a new key with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-very-long-random-secret-key-here-change-me

# Set to False in production
DJANGO_DEBUG=True

# Comma-separated list of allowed host/domain names
# Example: localhost,127.0.0.1,healthsec.yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# Set to 'postgresql' to use PostgreSQL, leave blank or 'sqlite' for SQLite
DB_ENGINE=sqlite

# PostgreSQL connection settings (only required when DB_ENGINE=postgresql)
DB_NAME=healthsec_db
DB_USER=healthsec_user
DB_PASSWORD=your_db_password_here
DB_HOST=localhost
DB_PORT=5432

# ---------------------------------------------------------------------------
# Email
# ---------------------------------------------------------------------------

# Use 'django.core.mail.backends.console.EmailBackend' during development
# Use 'django.core.mail.backends.smtp.EmailBackend' in production
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password-here
DEFAULT_FROM_EMAIL=HealthSec <noreply@healthsec.local>

# Site information for email links
SITE_NAME=HealthSec CRIC HMS
SITE_DOMAIN=localhost:8000

# ---------------------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing)
# ---------------------------------------------------------------------------

# Comma-separated list of origins allowed to make cross-origin API calls
# Example: http://localhost:3000,https://app.yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---------------------------------------------------------------------------
# Optional: External Threat Intelligence APIs
# ---------------------------------------------------------------------------

# NVD (National Vulnerability Database) API key for CVE lookups
# Get one at: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=your_nvd_api_key_here

# CISA Known Exploited Vulnerabilities feed (no key required, but nice to label)
CISA_KEV_URL=https://www.cisa.gov/sites/default/files/feeds/known_exploited_vulnerabilities.json

# ---------------------------------------------------------------------------
# Optional: Notification / Alerting Integrations
# ---------------------------------------------------------------------------

# Slack webhook URL for critical alert notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# ---------------------------------------------------------------------------
# Production Security (leave False in development)
# ---------------------------------------------------------------------------

# These are automatically derived from DJANGO_DEBUG in settings.py,
# but you can override them explicitly here if needed.
# SECURE_SSL_REDIRECT=False
# SESSION_COOKIE_SECURE=False
# CSRF_COOKIE_SECURE=False
